doctype html
html
  head
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Express Pug App
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    script(src="https://code.jquery.com/jquery-3.6.0.min.js")
  body
  - var loggined=true;
    if loggedin
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
        .container-fluid
          a.navbar-brand(href="#") MyApp
          button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarSupportedContent")
            span.navbar-toggler-icon
          #navbarSupportedContent.collapse.navbar-collapse
            ul.navbar-nav.ms-auto.mb-2.mb-lg-0
              li.nav-item
                a.nav-link(href="/logout") Logout

      .container-fluid
        .row
          // Sidebar
          .col-md-2.bg-light.d-none.d-md-block.sidebar
            ul.nav.flex-column.mt-3
              li.nav-item
                a.nav-link.active(href="#") Dashboard
              li.nav-item
                a.nav-link(href="#") Link 1
              li.nav-item
                a.nav-link(href="#") Link 2

          // Content
          .col-md-10.ms-sm-auto.p-4
            block content
    else
      block content
