extends ../layout
block content
  .container.mt-5
    .row.justify-content-center
      .col-md-4
        h3.text-center.mb-4 Login
        form#loginForm
          .mb-3
            input.form-control(type="text", name="username", placeholder="Username", required)
          .mb-3
            input.form-control(type="password", name="password", placeholder="Password", required)
          button.btn.btn-primary.w-100(type="submit") Login
        p.mt-3.text-danger#loginError
  script(src="js/login.js")

  